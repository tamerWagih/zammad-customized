# Database Configuration (must match docker-compose.yml defaults)
POSTGRES_DB=zammad_production
POSTGRES_USER=zammad
POSTGRES_PASS=zammad

# Redis Configuration
REDIS_URL=redis://zammad-redis:6379

# Elasticsearch Configuration  
ELASTICSEARCH_URL=http://zammad-elasticsearch:9200

# Memcached Configuration
MEMCACHE_SERVERS=zammad-memcached:11211

# Rails Configuration
RAILS_ENV=production
SECRET_KEY_BASE=your-secret-key-base-here

# Zammad Configuration
ZAMMAD_FQDN=localhost
ZAMMAD_URL=http://localhost:8080

# Skip translation sync to avoid line ending issues
SKIP_TRANSLATION_SYNC=true
