<% case action %>
<% when 'create' %>
<% if recipient.id == approval.approver_id %>
<%- self.T('Approval request for ticket #%s', ticket.number) %>
<% else %>
<%- self.T('Approval request sent for ticket #%s', ticket.number) %>
<% end %>
<% when 'update' %>
<% if recipient.id == approval.approver_id %>
<%- self.T('Approval request updated for ticket #%s', ticket.number) %>
<% else %>
<%- self.T('Approval request updated for ticket #%s', ticket.number) %>
<% end %>
<% when 'approve' %>
<% if recipient.id == approval.requester_id %>
<%- self.T('Approval granted for ticket #%s', ticket.number) %>
<% else %>
<%- self.T('Approval granted for ticket #%s', ticket.number) %>
<% end %>
<% when 'reject' %>
<% if recipient.id == approval.requester_id %>
<%- self.T('Approval rejected for ticket #%s', ticket.number) %>
<% else %>
<%- self.T('Approval rejected for ticket #%s', ticket.number) %>
<% end %>
<% when 'delete' %>
<% if recipient.id == approval.approver_id %>
<%- self.T('Approval request cancelled for ticket #%s', ticket.number) %>
<% else %>
<%- self.T('Approval request cancelled for ticket #%s', ticket.number) %>
<% end %>
<% end %>

<div style="font-family: Arial, sans-serif; max-width: 600px; margin: 0 auto;">
  <div style="background-color: #f8f9fa; padding: 20px; border-radius: 8px; margin-bottom: 20px;">
    <h2 style="color: #333; margin: 0 0 10px 0;">
      <% case action %>
      <% when 'create' %>
        <% if recipient.id == approval.approver_id %>
          <%- self.T('Approval Request') %>
        <% else %>
          <%- self.T('Approval Request Sent') %>
        <% end %>
      <% when 'update' %>
        <%- self.T('Approval Request Updated') %>
      <% when 'approve' %>
        <% if recipient.id == approval.requester_id %>
          <%- self.T('Approval Granted') %>
        <% else %>
          <%- self.T('Approval Granted') %>
        <% end %>
      <% when 'reject' %>
        <% if recipient.id == approval.requester_id %>
          <%- self.T('Approval Rejected') %>
        <% else %>
          <%- self.T('Approval Rejected') %>
        <% end %>
      <% when 'delete' %>
        <%- self.T('Approval Request Cancelled') %>
      <% end %>
    </h2>
    
    <div style="background-color: white; padding: 15px; border-radius: 4px; border-left: 4px solid #007bff;">
      <h3 style="margin: 0 0 10px 0; color: #333;">
        <%- self.T('Ticket #%s', ticket.number) %>: <%- ticket.title %>
      </h3>
      
      <% case action %>
      <% when 'create' %>
        <% if recipient.id == approval.approver_id %>
          <p style="margin: 10px 0; color: #666;">
            <%- self.T('%s has requested your approval for this ticket.', approval.requester.fullname) %>
          </p>
        <% else %>
          <p style="margin: 10px 0; color: #666;">
            <%- self.T('You have requested approval from %s for this ticket.', approval.approver.fullname) %>
          </p>
        <% end %>
      <% when 'update' %>
        <% if recipient.id == approval.approver_id %>
          <p style="margin: 10px 0; color: #666;">
            <%- self.T('%s has updated the approval request for this ticket.', approval.requester.fullname) %>
          </p>
        <% else %>
          <p style="margin: 10px 0; color: #666;">
            <%- self.T('You have updated the approval request for %s.', approval.approver.fullname) %>
          </p>
        <% end %>
      <% when 'approve' %>
        <% if recipient.id == approval.requester_id %>
          <p style="margin: 10px 0; color: #666;">
            <%- self.T('%s has approved your request for this ticket.', approval.approver.fullname) %>
          </p>
        <% else %>
          <p style="margin: 10px 0; color: #666;">
            <%- self.T('You have approved the request from %s for this ticket.', approval.requester.fullname) %>
          </p>
        <% end %>
      <% when 'reject' %>
        <% if recipient.id == approval.requester_id %>
          <p style="margin: 10px 0; color: #666;">
            <%- self.T('%s has rejected your request for this ticket.', approval.approver.fullname) %>
          </p>
        <% else %>
          <p style="margin: 10px 0; color: #666;">
            <%- self.T('You have rejected the request from %s for this ticket.', approval.requester.fullname) %>
          </p>
        <% end %>
      <% when 'delete' %>
        <% if recipient.id == approval.approver_id %>
          <p style="margin: 10px 0; color: #666;">
            <%- self.T('%s has cancelled the approval request for this ticket.', approval.requester.fullname) %>
          </p>
        <% else %>
          <p style="margin: 10px 0; color: #666;">
            <%- self.T('You have cancelled the approval request for %s.', approval.approver.fullname) %>
          </p>
        <% end %>
      <% end %>
      
      <% if approval.message.present? %>
        <div style="background-color: #f8f9fa; padding: 10px; border-radius: 4px; margin: 10px 0;">
          <strong><%- self.T('Message') %>:</strong>
          <p style="margin: 5px 0 0 0; color: #666;"><%- approval.message %></p>
        </div>
      <% end %>
      
      <div style="margin: 15px 0;">
        <strong><%- self.T('Priority') %>:</strong>
        <% case approval.priority %>
        <% when 'urgent' %>
          <span style="background-color: #dc3545; color: white; padding: 2px 8px; border-radius: 12px; font-size: 12px;">
            <%- self.T('Urgent') %>
          </span>
        <% when 'high' %>
          <span style="background-color: #fd7e14; color: white; padding: 2px 8px; border-radius: 12px; font-size: 12px;">
            <%- self.T('High') %>
          </span>
        <% when 'normal' %>
          <span style="background-color: #28a745; color: white; padding: 2px 8px; border-radius: 12px; font-size: 12px;">
            <%- self.T('Normal') %>
          </span>
        <% when 'low' %>
          <span style="background-color: #6c757d; color: white; padding: 2px 8px; border-radius: 12px; font-size: 12px;">
            <%- self.T('Low') %>
          </span>
        <% end %>
      </div>
      
      <% if approval.status %>
        <div style="margin: 10px 0;">
          <strong><%- self.T('Status') %>:</strong>
          <% case approval.status %>
          <% when 'approved' %>
            <span style="background-color: #28a745; color: white; padding: 2px 8px; border-radius: 12px; font-size: 12px;">
              <%- self.T('Approved') %>
            </span>
          <% when 'rejected' %>
            <span style="background-color: #dc3545; color: white; padding: 2px 8px; border-radius: 12px; font-size: 12px;">
              <%- self.T('Rejected') %>
            </span>
          <% when 'pending' %>
            <span style="background-color: #ffc107; color: #212529; padding: 2px 8px; border-radius: 12px; font-size: 12px;">
              <%- self.T('Pending') %>
            </span>
          <% end %>
        </div>
      <% end %>
      
      <div style="margin: 10px 0; color: #666;">
        <strong><%- self.T('Requested') %>:</strong> <%- approval.created_at.strftime('%B %d, %Y at %I:%M %p') %>
      </div>
    </div>
    
    <div style="text-align: center; margin: 20px 0;">
      <a href="<%- url %>" style="background-color: #007bff; color: white; padding: 12px 24px; text-decoration: none; border-radius: 4px; display: inline-block;">
        <%- self.T('View Ticket') %>
      </a>
    </div>
    
    <div style="margin-top: 20px; padding-top: 15px; border-top: 1px solid #dee2e6; color: #6c757d; font-size: 12px;">
      <p style="margin: 0;">
        <%- self.T('This is an automated notification from %s.', Setting.get('fqdn')) %>
      </p>
    </div>
  </div>
</div>
