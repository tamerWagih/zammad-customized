<% case @objects[:action] when 'create' %>You were CC'd on ticket (#{ticket.title})<% when 'delete' %>You were removed from CC on ticket (#{ticket.title})<% else %>CC notification for ticket (#{ticket.title})<% end %>

<div>Hi #{recipient.firstname},</div>
<br>
<% if @objects[:action] == 'create' %>
  <% creator_name = @objects[:creator]&.fullname || @objects[:creator_name] || 'Unknown User' %>
  <div>You have been <b>CC'd</b> on ticket "<b>#{ticket.title}</b>" by "<b>#{creator_name}</b>".</div>
  <div>You now have access to view and participate in this ticket.</div>
<% elsif @objects[:action] == 'delete' %>
  <div>You have been <b>removed from CC</b> on ticket "<b>#{ticket.title}</b>".</div>
  <div>You no longer have access to this ticket.</div>
<% else %>
  <div>There has been an update to the CC list for ticket "<b>#{ticket.title}</b>".</div>
<% end %>
<br>
<div>
Ticket: ##{ticket.number}<br>
Customer: #{ticket.customer.fullname}<br>
Group: #{ticket.group.name}<br>
<% if @objects[:cc][:message].present? %>
Message: #{@objects[:cc][:message]}<br>
<% end %>
</div>
<br>
<div>
  <a href="#{config.http_type}://#{config.fqdn}/#ticket/zoom/#{ticket.id}" target="zammad_app">View this in #{config.product_name}</a>
</div>

