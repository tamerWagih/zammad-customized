<% if action == 'create' %>
Ticket shared with your group (#{ticket.title})
<% elsif action == 'update' %>
Ticket share updated (#{ticket.title})
<% elsif action == 'revoke' %>
Ticket share revoked (#{ticket.title})
<% elsif action == 'delete' %>
Ticket share deleted (#{ticket.title})
<% else %>
Ticket share notification (#{ticket.title})
<% end %>

<div>Hi #{recipient.firstname},</div>
<br>
<% if action == 'create' %>
  <% if recipient.id == share.shared_by_id %>
    <div>You have <b>shared</b> ticket "<b>#{ticket.title}</b>" with group "<b>#{share.group.name}</b>".</div>
  <% else %>
    <div>Ticket "<b>#{ticket.title}</b>" has been <b>shared</b> with your group "<b>#{share.group.name}</b>" by "<b>#{share.shared_by.fullname}</b>".</div>
  <% end %>
<% elsif action == 'update' %>
  <% if recipient.id == share.shared_by_id %>
    <div>Your share settings for ticket "<b>#{ticket.title}</b>" have been updated.</div>
  <% else %>
    <div>The share settings for ticket "<b>#{ticket.title}</b>" (shared with your group) have been updated.</div>
  <% end %>
<% elsif action == 'revoke' %>
  <% if recipient.id == share.shared_by_id %>
    <div>You have <b>revoked</b> access to ticket "<b>#{ticket.title}</b>" for group "<b>#{share.group.name}</b>".</div>
  <% else %>
    <div>Access to ticket "<b>#{ticket.title}</b>" has been <b>revoked</b>.</div>
  <% end %>
<% elsif action == 'delete' %>
  <% if recipient.id == share.shared_by_id %>
    <div>Your share for ticket "<b>#{ticket.title}</b>" has been deleted.</div>
  <% else %>
    <div>The share for ticket "<b>#{ticket.title}</b>" (with your group) has been deleted.</div>
  <% end %>
<% else %>
<div>There has been an update to the share for ticket "<b>#{ticket.title}</b>".</div>
<% end %>
<br>
<div>
Ticket: ##{ticket.number}<br>
Group: #{share.group.name}<br>
Shared by: #{share.shared_by.fullname}<br>
<% if share.message.present? %>
Message: #{share.message}<br>
<% end %>
<% if share.expires_at.present? %>
Expires: #{share.expires_at.strftime('%Y-%m-%d')}<br>
<% end %>
</div>
<br>
<% unless ['revoke', 'delete'].include?(action) %>
<div>
  <a href="#{config.http_type}://#{config.fqdn}/#ticket/zoom/#{ticket.id}" target="zammad_app">View this in #{config.product_name}</a>
</div>
<% end %>
