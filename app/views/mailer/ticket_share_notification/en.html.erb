<% group_name = share.group_name %>
<% is_sharer = recipient.id == share.shared_by_id %>
<% group_label = group_name.present? ? group_name : self.T('the shared group') %>

<% case action %>
<% when 'create' %>
<%- self.T('Ticket #%s shared with %s', ticket.number, group_label) %>
<% when 'update' %>
<%- self.T('Ticket #%s share for %s updated', ticket.number, group_label) %>
<% when 'revoke', 'delete' %>
<%- self.T('Ticket #%s share for %s revoked', ticket.number, group_label) %>
<% end %>

<div style="font-family: Arial, sans-serif; max-width: 600px; margin: 0 auto;">
  <div style="background-color: #f8f9fa; padding: 20px; border-radius: 8px; margin-bottom: 20px;">
    <h2 style="color: #333; margin: 0 0 10px 0;">
      <% case action %>
      <% when 'create' %>
        <% if is_sharer %>
          <%- self.T('Ticket Shared Successfully') %>
        <% else %>
          <%- self.T('Ticket Shared with Your Group') %>
        <% end %>
      <% when 'update' %>
        <% if is_sharer %>
          <%- self.T('Share Updated Successfully') %>
        <% else %>
          <%- self.T('Share Settings Updated') %>
        <% end %>
      <% when 'revoke', 'delete' %>
        <% if is_sharer %>
          <%- self.T('Share Revoked Successfully') %>
        <% else %>
          <%- self.T('Group Access Revoked') %>
        <% end %>
      <% end %>
    </h2>
    
    <div style="background-color: white; padding: 15px; border-radius: 4px; border-left: 4px solid #007bff;">
      <h3 style="margin: 0 0 10px 0; color: #333;">
        <%- self.T('Ticket #%s', ticket.number) %>: <%- ticket.title %>
      </h3>
      
      <% case action %>
      <% when 'create' %>
        <% if is_sharer %>
          <p style="margin: 10px 0; color: #666;">
            <%- self.T('You have successfully shared this ticket with the group %s.', group_label) %>
          </p>
        <% else %>
          <p style="margin: 10px 0; color: #666;">
            <%- self.T('%s granted your group full access to this ticket.', actor.fullname) %>
          </p>
        <% end %>
      <% when 'update' %>
        <% if is_sharer %>
          <p style="margin: 10px 0; color: #666;">
            <%- self.T('You have updated the share for the group %s.', group_label) %>
          </p>
        <% else %>
          <p style="margin: 10px 0; color: #666;">
            <%- self.T('%s updated the share settings for your group.', actor.fullname) %>
          </p>
        <% end %>
      <% when 'revoke', 'delete' %>
        <% if is_sharer %>
          <p style="margin: 10px 0; color: #666;">
            <%- self.T('You have revoked the share for the group %s.', group_label) %>
          </p>
        <% else %>
          <p style="margin: 10px 0; color: #666;">
            <%- self.T('%s revoked your group access to this ticket.', actor.fullname) %>
          </p>
        <% end %>
      <% end %>
      
      <% if share.message.present? %>
        <div style="background-color: #f8f9fa; padding: 10px; border-radius: 4px; margin: 10px 0;">
          <strong><%- self.T('Message') %>:</strong>
          <p style="margin: 5px 0 0 0; color: #666;"><%- share.message %></p>
        </div>
      <% end %>
      
      <div style="margin: 15px 0;">
        <strong><%- self.T('Access Level') %>:</strong>
        <span style="background-color: #28a745; color: white; padding: 2px 8px; border-radius: 12px; font-size: 12px;">
          <%- self.T('Full access for group members') %>
        </span>
      </div>
      
      <% if share.expires_at %>
        <div style="margin: 10px 0; color: #666;">
          <strong><%- self.T('Expires') %>:</strong> <%- share.expires_at.strftime('%B %d, %Y') %>
        </div>
      <% end %>
    </div>
    
    <div style="text-align: center; margin: 20px 0;">
      <a href="<%- url %>" style="background-color: #007bff; color: white; padding: 12px 24px; text-decoration: none; border-radius: 4px; display: inline-block;">
        <%- self.T('View Ticket') %>
      </a>
    </div>
    
    <div style="margin-top: 20px; padding-top: 15px; border-top: 1px solid #dee2e6; color: #6c757d; font-size: 12px;">
      <p style="margin: 0;">
        <%- self.T('This is an automated notification from %s.', Setting.get('fqdn')) %>
      </p>
    </div>
  </div>
</div>
