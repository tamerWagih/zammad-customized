<% case action %>
<% when 'create' %>
<%= self.T('Ticket #%s shared with your group', ticket.number) %>
<% when 'update' %>
<%= self.T('Ticket #%s share updated', ticket.number) %>
<% when 'revoke' %>
<%= self.T('Ticket #%s share revoked', ticket.number) %>
<% when 'delete' %>
<%= self.T('Ticket #%s share deleted', ticket.number) %>
<% else %>
<%= self.T('Ticket #%s share notification', ticket.number) %>
<% end %>

<div style="font-family: Arial, sans-serif; max-width: 600px; margin: 0 auto;">
  <div style="background-color: #f8f9fa; padding: 20px; border-radius: 8px; margin-bottom: 20px;">
    <h2 style="color: #333; margin: 0 0 10px 0;">
      <% case action %>
      <% when 'create' %>
        <%= self.T('Ticket Shared with Your Group') %>
      <% when 'update' %>
        <%= self.T('Ticket Share Updated') %>
      <% when 'revoke' %>
        <%= self.T('Ticket Share Revoked') %>
      <% when 'delete' %>
        <%= self.T('Ticket Share Deleted') %>
      <% else %>
        <%= self.T('Ticket Share Notification') %>
      <% end %>
    </h2>
    
    <p style="color: #666; margin: 0;">
      <%= self.T('Hello %s,', recipient.firstname) %>
    </p>
  </div>

  <div style="background-color: #fff; padding: 20px; border: 1px solid #ddd; border-radius: 8px; margin-bottom: 20px;">
    <h3 style="color: #333; margin: 0 0 15px 0;">
      <%= self.T('Ticket Details') %>
    </h3>
    
    <table style="width: 100%; border-collapse: collapse;">
      <tr>
        <td style="padding: 8px 0; border-bottom: 1px solid #eee; font-weight: bold; width: 30%;">
          <%= self.T('Ticket #') %>
        </td>
        <td style="padding: 8px 0; border-bottom: 1px solid #eee;">
          <%= ticket.number %>
        </td>
      </tr>
      <tr>
        <td style="padding: 8px 0; border-bottom: 1px solid #eee; font-weight: bold;">
          <%= self.T('Title') %>
        </td>
        <td style="padding: 8px 0; border-bottom: 1px solid #eee;">
          <%= ticket.title %>
        </td>
      </tr>
      <tr>
        <td style="padding: 8px 0; border-bottom: 1px solid #eee; font-weight: bold;">
          <%= self.T('Group') %>
        </td>
        <td style="padding: 8px 0; border-bottom: 1px solid #eee;">
          <%= share.group_name %>
        </td>
      </tr>
      <tr>
        <td style="padding: 8px 0; border-bottom: 1px solid #eee; font-weight: bold;">
          <%= self.T('Shared By') %>
        </td>
        <td style="padding: 8px 0; border-bottom: 1px solid #eee;">
          <%= share.shared_by_name %>
        </td>
      </tr>
      <% if share.message.present? %>
      <tr>
        <td style="padding: 8px 0; border-bottom: 1px solid #eee; font-weight: bold; vertical-align: top;">
          <%= self.T('Message') %>
        </td>
        <td style="padding: 8px 0; border-bottom: 1px solid #eee;">
          <%= simple_format(share.message) %>
        </td>
      </tr>
      <% end %>
      <% if share.expires_at.present? %>
      <tr>
        <td style="padding: 8px 0; border-bottom: 1px solid #eee; font-weight: bold;">
          <%= self.T('Expires') %>
        </td>
        <td style="padding: 8px 0; border-bottom: 1px solid #eee;">
          <%= l(share.expires_at, format: :long) %>
        </td>
      </tr>
      <% end %>
    </table>
  </div>

  <div style="text-align: center; margin: 20px 0;">
    <a href="<%= url %>" style="background-color: #007bff; color: white; padding: 12px 24px; text-decoration: none; border-radius: 4px; display: inline-block; font-weight: bold;">
      <%= self.T('View Ticket') %>
    </a>
  </div>

  <div style="background-color: #f8f9fa; padding: 15px; border-radius: 8px; font-size: 12px; color: #666;">
    <p style="margin: 0;">
      <%= self.T('This notification was sent because a ticket was shared with your group. Only agents and admins in the group receive access.') %>
    </p>
    <p style="margin: 10px 0 0 0;">
      <%= self.T('You can manage your notification preferences in your user profile.') %>
    </p>
  </div>
</div>